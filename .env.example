# Production environment — copy to .env and fill in secrets
# Used by docker-compose.yml

# Server ports (defaults: 8080 / 8081)
GALLERY_PUBLIC_PORT=8080
GALLERY_PRIVATE_PORT=8081

# Ed25519 public key for verifying sync request signatures (base64-encoded, 32 bytes)
# Required. Generate with:
#   openssl genpkey -algorithm ed25519 -out ed25519.pem
#   openssl pkey -in ed25519.pem -pubout -outform DER | tail -c 32 | base64
GALLERY_ED25519_PUBLIC_KEY=

# Cloudflare tunnel token (from Cloudflare Zero Trust dashboard)
CLOUDFLARE_TUNNEL_TOKEN=
